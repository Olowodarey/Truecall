# ─── Deployer ─────────────────────────────────────────────────────────────────
# Your wallet private key (with 0x prefix) — NEVER commit the real value
PRIVATE_KEY=0x_your_private_key_here

# ─── Addresses (optional — defaults to deployer if not set) ───────────────────
# Wallet that receives the 1% platform fee
TREASURY_ADDRESS=0x_your_treasury_address_here

# AI Agent wallet address (the off-chain agent that calls submitMatchResult)
# This is the PUBLIC address of the ai-agent wallet, not the private key
AI_AGENT_ADDRESS=0x_your_agent_wallet_address_here

# ─── Celoscan (for --verify flag) ─────────────────────────────────────────────
# Get your key at https://celoscan.io/myapikey
CELOSCAN_API_KEY=your_celoscan_api_key_here
