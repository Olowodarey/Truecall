# ─── Celo Network ─────────────────────────────────────────────────────────────
# RPC URL for Celo
# Mainnet:     https://forno.celo.org
# Celo Sepolia testnet: https://forno.celo-sepolia.celo-testnet.org
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# AI Agent wallet private key (this wallet must be set as aiOracleAgent in EventManager)
# NEVER commit this value — keep it secret
AGENT_PRIVATE_KEY=0xyour_private_key_here

# ─── Contract Addresses ───────────────────────────────────────────────────────
# EventManager proxy address (deployed on Celo)
EVENT_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000

# ─── API-Football ─────────────────────────────────────────────────────────────
# Get your key at https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ─── Agent Config ─────────────────────────────────────────────────────────────
# How often to poll for pending matches (milliseconds). Default: 60000 (1 min)
POLL_INTERVAL_MS=60000

# How many blocks back to scan for MatchAdded events on startup
STARTUP_BLOCK_LOOKBACK=10000

# Log level: error | warn | info | debug
LOG_LEVEL=info
